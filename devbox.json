{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.14.0/.schema/devbox.schema.json",
  "packages": [
    "kubernetes-helm@3.10.0",
    "pre-commit@4.3.0",
    "goreleaser@1.16.1",
    "gotestsum@1.10.0",
    "gnumake@4.4.1",
    "shfmt@3.8.0",
    "go@latest",
    "golangci-lint@latest"
  ],
  "shell": {
    "scripts": {
      "lint": [
        "make lint"
      ],
      "test": [
        "make test"
      ],
      "build-snapshot": [
        "make build-snapshot"
      ],
      "release-snapshot": [
        "make release-snapshot"
      ],
      "release": [
        "make release"
      ],
      "pre-commit-install": [
        "pre-commit install --install-hooks"
      ]
    }
  }
}
